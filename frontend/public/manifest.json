{
	"manifest_version": 3,
	"name": "Hello World",
	"version": "1.0",
	"description": "Hello World",
	"action": {
		"default_popup": "index.html",
		"default_title": "Hello World"
	},
	"permissions": ["storage"],
	"background": {
		"service_worker": ["background.js"],
		"type": "module"
	},
	"host_permissions": [
		"https://script.google.com/*",
		"https://script.googleusercontent.com/*"
	]
}
