{
	"manifest_version": 3,
	"name": "JobTrackr",
	"version": "1.0",
	"description": "Job Tracking Extension",
	"action": {
		"default_popup": "index.html",
		"default_title": "Hello World"
	},
	"permissions": ["storage"],
	"content_scripts": [
		{
			"matches": [
				"*://*.linkedin.com/*",
				"*://*.indeed.com/*",
				"*://*.glassdoor.com/*",
				"*://*.handshake.com/*"
			],
			"js": ["content.js"],
			"run_at": "document_end"
		}
	],
	"background": {
		"service_worker": "background.js",
		"type": "module"
	},
	"host_permissions": [
		"https://script.google.com/*",
		"https://script.googleusercontent.com/*"
	]
}
